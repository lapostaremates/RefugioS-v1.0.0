# Auto detect text files and perform LF normalization
* text=auto

# Force shell scripts to always use LF (critical for Linux CI runners)
gradlew text eol=lf
*.sh text eol=lf

# Windows scripts use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - never convert
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
*.apk binary
*.aab binary
*.keystore binary
